# Copia a .env solo si necesitas valores en build (Vite).
#
# Botón flotante de ayuda (wa.me). Solo dígitos, con código de país (ej. 573001234567).
# Si no se define, se usa un número de respaldo del proyecto.
# VITE_WHATSAPP_HELP_NUMBER=
#
# Embedded Signup (FB.login WhatsApp): Meta solo lo permite a BSP/TP.
# NO pongas true salvo que tu app sea partner. Por defecto (sin esta variable) = OAuth clásico.
# VITE_USE_EMBEDDED_SIGNUP=false

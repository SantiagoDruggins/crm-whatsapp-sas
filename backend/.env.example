# ===========================================
# Ejemplo de variables de entorno (backend)
# Copia a .env y rellena los valores reales.
# ===========================================

NODE_ENV=production
PORT=4000

# JWT
JWT_SECRET=tu_clave_secreta_muy_larga_y_aleatoria
JWT_EXPIRES_IN=7d

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_password
DB_NAME=saas_crm_multitenant

# ---- Gemini (Google AI) ----
# API key: créala en https://aistudio.google.com/apikey
# Para cuota de pago: enlaza el proyecto a facturación en Google Cloud.
GEMINI_API_KEY=tu_api_key_de_gemini
GEMINI_MODEL=gemini-2.5-pro
# Modelo TTS para generar audio desde texto (opcional). Fallback: gemini-2.5-pro-preview-tts
# GEMINI_TTS_MODEL=gemini-2.5-pro-preview-tts
GEMINI_TEMPERATURE=0.4
GEMINI_TOP_P=0.9
# Máximo de tokens en la respuesta (8192 por defecto)
GEMINI_MAX_OUTPUT_TOKENS=8192

# ---- OpenAI (opcional, para IA o para que el bot envíe respuestas en audio) ----
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Envía también la respuesta del bot como nota de voz. Si hay GEMINI_API_KEY se usa Gemini TTS primero; si no, OpenAI TTS.
# BOT_ENVIAR_RESPUESTA_EN_AUDIO=false

# ---- Anthropic (opcional) ----
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ---- Grok / xAI (opcional) ----
# GROK_API_KEY=xaikey-...
# GROK_MODEL=grok-2-latest

# ---- WhatsApp Cloud API (global para verificación del webhook) ----
WHATSAPP_CLOUD_VERIFY_TOKEN=tu_verify_token_secreto
PUBLIC_API_URL=https://dsgchatbot.pro/
# URL pública de la app (para que las fotos de productos enviadas por WhatsApp se vean y para OAuth redirect)
PUBLIC_APP_URL=https://dsgchatbot.pro
# WHATSAPP_CLOUD_PHONE_NUMBER_ID y token por empresa: se configuran por OAuth (Conectar con Facebook)

# ---- Facebook OAuth (conexión "Conectar con Facebook" en el panel WhatsApp) ----
# Crea una app en https://developers.facebook.com y añade producto "Facebook Login" y "WhatsApp".
# En Facebook Login → Configuración: URL de redirección OAuth válida = https://TU_DOMINIO/api/facebook/callback
FACEBOOK_APP_ID=tu_app_id
FACEBOOK_APP_SECRET=tu_app_secret
# Embedded Signup (FB.login + config_id): Meta solo lo permite para apps BSP / Tech Provider.
# Por defecto desactivado: se usa OAuth en ventana (redirect). Pon true solo si eres partner aprobado.
# FACEBOOK_USE_EMBEDDED_SIGNUP=false
# Si usas Embedded Signup: ID de configuración en Meta (Registro insertado).
# FACEBOOK_EMBEDDED_SIGNUP_CONFIG_ID=9744
# Permisos del OAuth clásico (coma). En la app Meta añade estos permisos y revisión si aplica.
# FACEBOOK_OAUTH_SCOPES=public_profile,business_management,whatsapp_business_management,whatsapp_business_messaging

# ---- CORS (opcional) ----
# CORS_ORIGIN=https://tudominio.com

# ---- Dropi (opcional; cada empresa puede poner su URL en el panel Integraciones) ----
# DROPI_API_BASE_URL=https://api.dropi.co
# DROPI_API_KEY_HEADER=Authorization

# ---- Email (recuperación de contraseña) ----
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=tu@gmail.com, SMTP_PASS=contraseña de aplicación
# SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey, SMTP_PASS=tu_api_key
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Remitente visible en el correo (opcional; si no se pone, se usa SMTP_USER)
# EMAIL_FROM=ChatProBusiness <noreply@tudominio.com>
